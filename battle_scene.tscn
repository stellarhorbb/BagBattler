[sub_resource type="Shader" id="Shader_vig001"]
code = "shader_type canvas_item;
void fragment() {
	vec2 uv = UV;
	float vignette = smoothstep(0.35, 0.75, length(uv - vec2(0.5)));
	COLOR = vec4(1.0, 0.0, 0.0, vignette * 0.45);
}"

