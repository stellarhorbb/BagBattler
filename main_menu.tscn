[sub_resource type="Shader" id="Shader_wave"]
code = "shader_type canvas_item;

uniform float wave_y : hint_range(0.0, 1.0) = 0.44;
uniform float speed : hint_range(0.0, 5.0) = 0.9;
uniform float amplitude : hint_range(0.0, 0.3) = 0.10;
uniform vec4 color : source_color = vec4(0.067, 0.067, 0.067, 1.0);

void fragment() {
	float x = UV.x;
	float y = UV.y;

	// Asymmetric base drift — pulls the wave left-heavy
	float wave = sin(x * 1.7 + TIME * speed * 0.8 + 1.3) * amplitude * 0.55;

	// Mid-frequency bumps, out of phase with each other
	wave += sin(x * 3.9 - TIME * speed * 1.1 + 0.7) * amplitude * 0.35;
	wave += sin(x * 6.2 + TIME * speed * 0.5 + 2.1) * amplitude * 0.20;

	// High-freq jitter for rough, hand-drawn feel
	wave += sin(x * 11.4 - TIME * speed * 1.7 + 0.4) * amplitude * 0.10;
	wave += sin(x * 17.8 + TIME * speed * 2.3 + 3.5) * amplitude * 0.05;

	// Slow broad swell that shifts the whole silhouette asymmetrically
	wave += sin(x * 0.6 - TIME * speed * 0.3 + 1.9) * amplitude * 0.30;

	float edge = wave_y + wave;

	float blend = smoothstep(edge + 0.0005, edge - 0.0005, y);
	COLOR = vec4(color.rgb, blend * color.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_wave"]
shader = SubResource("Shader_wave")
shader_parameter/wave_y = 0.44
shader_parameter/speed = 0.9
shader_parameter/amplitude = 0.1
shader_parameter/color = Color(1, 1, 1, 1)

